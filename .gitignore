output/
logs/
reports/html/
reports/pdf/

# ── Sensitive Config ──────────────────────────────────────────
# API keys, secrets — never commit
.env
.env.*
config/targets.txt

# ── Wordlists ─────────────────────────────────────────────────
# Too large for git, downloaded at setup
config/wordlists/

# ── SQLMap Session Files ──────────────────────────────────────
.sqlmap/

# ── Playwright ────────────────────────────────────────────────
playwright-report/
test-results/

# ── macOS ─────────────────────────────────────────────────────
.DS_Store
.AppleDouble
.LSOverride
._*
.Spotlight-V100
.Trashes

# ── IDE ───────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*~

# ── Pytest ────────────────────────────────────────────────────
.pytest_cache/
.coverage
htmlcov/

# ── Misc ──────────────────────────────────────────────────────
*.log
*.tmp
*.bak
EOF