# ── Python ────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python
*.egg
*.egg-info/
dist/
build/
eggs/
parts/
var/
sdist/
develop-eggs/
.installed.cfg
lib/
lib64/

# ── Virtual Environment ───────────────────────────────────────
venv/
env/
ENV/
.venv/

# ── PHANTOM Scan Output ───────────────────────────────────────
